{erl_opts, [debug_info]}.
{deps, [
    {eqwalizer_support,
        {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {branch, "main"},
            "eqwalizer_support"}}
]}.

{shell, [
    %% {config, "config/sys.config"},
    {apps, [ebb]}
]}.

{erlfmt, [
    write,
    {print_width, 84}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_hank,
    rebar3_ex_doc,
    erlfmt
]}.

{hank, [
    {ignore, [
        {"include/dhcp.hrl", [single_use_hrls, single_use_hrl_attrs]}
    ]}
]}.
